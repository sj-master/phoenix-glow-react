{
  "name": "phoenix-glow-react",
  "version": "2.1.0",
  "description": "PHX-IT • Phoenix UI by Skyler Jones — a full React component library: the self-contained neon Glow kit plus 37 Tailwind + Radix UI components.",
  "author": "Skyler Jones <PHX-IT>",
  "homepage": "https://phoenixsecure.dev",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./styles/phoenix-glow.css": "./src/styles/phoenix-glow.css",
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.esm.js",
      "require": "./dist/tailwind-preset.js"
    },
    "./styles/phoenix-tokens.css": "./src/styles/phoenix-tokens.css"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.11",

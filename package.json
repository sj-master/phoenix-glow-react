    "glow",
    "phoenix",
    "shadcn",
    "radix",
    "tailwind",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sj-master/phoenix-glow-react.git"
  },
  "bugs": {
    "url": "https://github.com/sj-master/phoenix-glow-react/issues"
  }
